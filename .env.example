# Example environment variables for local development.
# Copy this file to `.env.local` and replace values as needed.

# Public Reown project ID used by `@reown/appkit` / `wagmi` (required for wallet UI)
NEXT_PUBLIC_PROJECT_ID=your_public_project_id_here

# Optional: API proxy base used by client-side helpers. Default route is `/api`.
# Use only if you've changed the API route prefix in the app.
NEXT_PUBLIC_API_BASE=/api

# Optional runtime values
# PORT=3000
# NODE_ENV=development

# WARNING: The app uses KuCoin public endpoints for market data (no API key required).
# If you add server-side private KuCoin integrations, keep these secrets out of client bundles
# and set them only on the server or in your deployment provider's secret store.
# Example (server-only, DO NOT COMMIT actual secrets):
# KUCOIN_API_KEY=your_api_key_here
# KUCOIN_API_SECRET=your_api_secret_here
# KUCOIN_API_PASSPHRASE=your_passphrase_here